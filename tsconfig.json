{
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "target": "es2021",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,

    "strict": true,
    "strictPropertyInitialization": false,
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true
  }
}
